# Choose exactly one live provider: ollama | vllm | groq | custom_openai_compatible_endpoint
LLM_PROVIDER=ollama

# Ollama
OLLAMA_MODEL=your-local-model-name
OLLAMA_BASE_URL=http://host.docker.internal:11434

# vLLM
VLLM_MODEL=your-vllm-model-name
VLLM_BASE_URL=http://host.docker.internal:8888/v1
VLLM_API_KEY=not-required-for-local-vllm

# Groq
GROQ_MODEL=your-groq-model-name
GROQ_API_KEY=

# Any OpenAI-compatible local or remote endpoint
CUSTOM_OPENAI_MODEL=your-compatible-model-name
CUSTOM_OPENAI_BASE_URL=http://host.docker.internal:8888/v1
OPENAI_API_KEY=

# Optional web research and currency services
TAVILY_API_KEY=
EXCHANGERATE_API_KEY=

# Local data runtime
POSTGRES_USER=dld
POSTGRES_PASSWORD=change-me-for-local-demo
POSTGRES_DB=dld_db
DATABASE_URL=postgresql://dld:change-me-for-local-demo@postgres:5432/dld_db
DATA_SERVICE_HOST=0.0.0.0
DATA_SERVICE_PORT=8000
AIZEN_SNAPSHOT_DATE=2026-07-02
AIZEN_SNAPSHOT_ID=active-2026-07-02-v1
AIZEN_RUN_TIMEOUT_SECONDS=120

# Optional tracing; disabled by default
LANGSMITH_TRACING=false
LANGSMITH_API_KEY=
LANGSMITH_PROJECT=agentic-property
