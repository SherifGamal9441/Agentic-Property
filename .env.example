# ── LLM ──────────────────────────────────────────────────────────────────────
LLM_PROVIDER=ollama          # ollama | vllm | groq

# Ollama — load your GGUF locally (each dev does this once):
#   ollama create llama3-property -f Modelfile
#   where Modelfile contains:  FROM /absolute/path/to/Meta-Llama-3.1-8B-Instruct-Q6_K_L.gguf
OLLAMA_MODEL=llama3-kpis
OLLAMA_BASE_URL=http://localhost:11434

# vLLM — production GPU server (set LLM_PROVIDER=vllm to activate)
VLLM_BASE_URL=http://localhost:8000/v1
VLLM_API_KEY=token-abc123

# ── Agent ─────────────────────────────────────────────────────────────────────
MAX_RETRIES=3
MIN_CONFIDENCE_THRESHOLD=0.6

# ── Teammates (kept for compatibility) ────────────────────────────────────────
GROQ_API_KEY=
OPENAI_API_KEY=

# ---- Data Service ----
#https://rapidapi.com/taviansol/api/uae-real-estate2
DATABASE_URL=postgresql://dld:dld_pass@postgres:5432/dld_db
RAPIDAPI_KEY=your_rapidapi_key_here

# Scraper tuning (optional, defaults are fine)
SEARCH_PAGE_SIZE=25
SCRAPER_MAX_LISTINGS=90
SCRAPER_CONCURRENCY=3
SCRAPER_REQUEST_DELAY=0.5
SCRAPER_REFRESH_DAYS=7
SCRAPER_OUTPUT=db

OUTPUT_CSV_PATH=data/active_dld.csv
LAST_RUN_PATH=last_run.json

# ---- MCP Server ----
#https://exchangerate.host
DATA_SERVICE_URL=http://data-service:8000
EXCHANGERATE_API_KEY=your_exchangerate_api_key_here   