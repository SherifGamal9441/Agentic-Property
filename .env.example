# ── LLM ───────────────────────────────────────────────────────────────────────
LLM_PROVIDER=custom_openai_compatible_endpoint   # ollama | vllm | groq | custom_openai_compatible_endpoint

# Ollama — load your GGUF locally (each dev does this once):
#   ollama create llama3-property -f Modelfile
#   where Modelfile contains:  FROM /absolute/path/to/Meta-Llama-3.1-8B-Instruct-Q6_K_L.gguf
OLLAMA_MODEL=llama3-kpis
OLLAMA_BASE_URL=http://localhost:11434

# vLLM — production GPU server (set LLM_PROVIDER=vllm to activate)
VLLM_BASE_URL=http://localhost:8000/v1
VLLM_API_KEY=token-abc123

# Custom OpenAI-compatible endpoint (Unsloth Studio, llama.cpp, etc.)
CUSTOM_OPENAI_MODEL=jackrong/Qwopus3.5-4B-Coder-MTP-GGUF:Q4_K_M
CUSTOM_OPENAI_BASE_URL=http://localhost:8888/v1
OPENAI_API_KEY=your_openai_api_key_here

# ── Agent ─────────────────────────────────────────────────────────────────────
MAX_RETRIES=3
MIN_CONFIDENCE_THRESHOLD=0.6

# ── Secrets (API keys only — connection params are in config/mcp.yaml) ────────
GROQ_API_KEY=
RAPIDAPI_KEY=your_rapidapi_key_here              # https://rapidapi.com/taviansol/api/uae-real-estate2
EXCHANGERATE_API_KEY=your_exchangerate_api_key   # https://exchangerate.host

# ── Data service (Docker only — override defaults if needed) ──────────────────
DATABASE_URL=postgresql://dld:***@postgres:5432/dld_db

# Scraper tuning (optional, defaults are fine)
SEARCH_PAGE_SIZE=25
SCRAPER_MAX_LISTINGS=90
SCRAPER_CONCURRENCY=3
SCRAPER_REQUEST_DELAY=0.5
SCRAPER_REFRESH_DAYS=7
SCRAPER_OUTPUT=db
OUTPUT_CSV_PATH=data/active_dld.csv
LAST_RUN_PATH=last_run.json
